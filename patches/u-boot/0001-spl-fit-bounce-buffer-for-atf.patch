+static ulong spl_fit_get_bounce_addr(size_t size)
+{
+	ulong addr;
+
+	/*
+	 * Keep the bounce buffer away from BL33 load area. Using
+	 * CONFIG_SYS_LOAD_ADDR here can overlap the U-Boot image itself.
+	 */
+	if (gd->ram_top > (CFG_SYS_SDRAM_BASE + SZ_16M + size))
+		addr = gd->ram_top - SZ_16M;
+	else
+		addr = CONFIG_SYS_LOAD_ADDR + SZ_16M;
+
+	return ALIGN_DOWN(addr, ARCH_DMA_MINALIGN);
+}
